#include "RunAction.hh"
#include "G4Run.hh"
#include "G4AnalysisManager.hh" // Include per ROOT output

RunAction::RunAction()
: G4UserRunAction()
{
    // Initialize the analysis manager
    analysisManager = G4AnalysisManager::Instance();
    analysisManager->SetFileName("../data/CrystallHits.root");
    analysisManager->CreateNtuple("Hits", "Crystal hits data");
    analysisManager->CreateNtupleIColumn("CrystalID");
    analysisManager->CreateNtupleDColumn("EnergyDeposited");
    analysisManager->FinishNtuple();
}

RunAction::~RunAction()
{
    // Cleanup if needed
    analysisManager->CloseFile();
}

