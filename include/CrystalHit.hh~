#ifndef CRYSTALHIT_HH
#define CRYSTALHIT_HH

#include "G4VHit.hh"

class CrystalHit : public G4VHit {
public:
  CrystalHit();
  virtual ~CrystalHit();

  // Metodi per impostare e ottenere l'ID del cristallo
  void SetID(G4int id) { fID = id; }
  G4int GetID() const { return fID; }

  // Metodi per impostare e ottenere l'energia depositata
  void SetEdep(G4double edep) { fEdep = edep; }
  G4double GetEdep() const { return fEdep; }

private:
  G4int fID;        // ID del cristallo
  G4double fEdep;   // Energia depositata
};

#endif // CRYSTALHIT_HH
