#ifndef CrystalSD_h
#define CrystalSD_h

#include "G4VSensitiveDetector.hh"
#include "G4THitsCollection.hh"
#include "G4VHit.hh"
#include "globals.hh"

class CrystalHit : public G4VHit {
public:
    CrystalHit();
    virtual ~CrystalHit();

    void AddEnergy(G4double energy);
    G4double GetEnergyDep() const;

private:
    G4double energyDep;
};

class CrystalSD : public G4VSensitiveDetector {
public:
    CrystalSD(const G4String& name);
    virtual ~CrystalSD();

    virtual void Initialize(G4HCofThisEvent* hce) override;
    virtual G4bool ProcessHits(G4Step* step, G4TouchableHistory* hist) override;
    virtual void EndOfEvent(G4HCofThisEvent* hce) override;

private:
    G4THitsCollection<CrystalHit>* fHitsCollection;
};

#endif
